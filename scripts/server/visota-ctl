# ===== CLI MODE (non-interactive) =====

cmd_cli() {
    case "${1:-help}" in
        install)  check_root; _full_install "${2:-}" ;;
        deploy)   check_root; shift; _cli_deploy "$@" ;;
        update)   check_root; cmd_update ;;
        status)   cmd_status ;;
        apps)     cmd_apps ;;
        logs)     cmd_logs "${2:-web}" ;;
        restart)  check_root; cd "$APP_DIR" 2>/dev/null && docker compose restart "${2:-}" ;;
        backup)   check_root; cmd_backup ;;
        restore)  check_root; _cli_restore "${2:-}" ;;
        shell)    cd "$APP_DIR" 2>/dev/null && docker compose exec "${2:-web}" bash ;;
        ssl)      cmd_ssl ;;
        security) check_root; cmd_security ;;
        cleanup)  check_root; cmd_cleanup ;;
        manage)   cd "$APP_DIR" 2>/dev/null && docker compose exec web python manage.py "${2:-help}" ;;
        help|--help|-h) _show_help ;;
        *)  err "Lệnh không rõ: $1"; _show_help; exit 1 ;;
    esac
}

_full_install() {
    local email="${1:-admin@visota.net}"
    show_header
    title "FULL INSTALL"
    dnf update -y
    dnf remove -y podman buildah runc 2>/dev/null || true
    dnf install -y dnf-utils
    dnf config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo
    dnf install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
    systemctl enable --now docker
    systemctl enable --now firewalld
    firewall-cmd --permanent --add-service={ssh,http,https}; firewall-cmd --reload
    docker network create web 2>/dev/null || true
    mkdir -p /opt/traefik/letsencrypt
    _write_traefik_compose
    _write_traefik_config "$email"
    cd /opt/traefik && docker compose up -d
    _install_security
    usermod -aG docker "${SUDO_USER:-$USER}"
    ok "Install complete — deploy: visota-ctl deploy visota [domain]"
}

_cli_deploy() {
    local app="${1:-}"; local domain="${2:-}"
    case "$app" in
        visota)    _deploy_visota "${domain:-visota.net}" ;;
        portainer) _deploy_portainer "${domain:-docker.visota.net}" ;;
        metabase)  _deploy_metabase "${domain:-analytics.visota.net}" ;;
        n8n)       _deploy_n8n "${domain:-flow.visota.net}" ;;
        *) err "Unknown app: $app"; echo "Available: visota, portainer, metabase, n8n"; exit 1 ;;
    esac
}

_cli_restore() {
    local f="$1"
    [ -z "$f" ] && { ls -lht "$BACKUP_DIR"/*.sql.gz 2>/dev/null | head -10; echo ""; err "Usage: visota-ctl restore <file>"; return; }
    source "$APP_DIR/.env"
    cd "$APP_DIR"
    gunzip < "$BACKUP_DIR/$f" | docker compose exec -T db mysql -u root -p"${DB_ROOT_PASSWORD}" "${DB_NAME:-visota}"
    docker compose restart web worker
    ok "Restored from $f"
}

_show_help() {
    cat << 'HELP'
visota-ctl v2 — Visota Server Control Panel

INTERACTIVE:  sudo visota-ctl                (hiện menu)
CLI:          sudo visota-ctl <command>

COMMANDS:
  install [email]              Cài Docker + Traefik + security
  deploy <app> [domain]        Deploy app (visota/portainer/metabase/n8n)
  update                       Update Visota
  status                       System status
  apps                         Container list
  logs [service]               View logs
  restart [service]            Restart
  backup                       Backup DB + media
  restore <file>               Restore DB
  shell [service]              Container shell
  manage <cmd>                 Django manage command
  ssl                          SSL certificates
  security                     Security audit
  cleanup                      Docker cleanup
  help                         This help
HELP
}

# ===== ENTRY POINT =====

if [ $# -gt 0 ]; then
    cmd_cli "$@"
else
    menu_main
fi
