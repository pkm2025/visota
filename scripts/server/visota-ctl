#!/bin/bash
# ============================================================
#  visota-ctl — Visota Server Control Panel v2
#  Interactive menu — giống centminmod
#  Usage: sudo visota-ctl  (hiện menu)
#         sudo visota-ctl <command>  (chạy trực tiếp)
# ============================================================

set -euo pipefail

APP_DIR="/opt/visota"
TRAEFIK_DIR="/opt/traefik"
PORTAINER_DIR="/opt/portainer"
BACKUP_DIR="/opt/visota/backups"
LOG_FILE="/var/log/visota-ctl.log"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; MAGENTA='\033[0;35m'
BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

log()     { echo -e "[$(date '+%H:%M:%S')] $1" >> "$LOG_FILE" 2>/dev/null || true; }
info()    { echo -e "${BLUE}ℹ${NC}  $1"; }
ok()      { echo -e "${GREEN}✓${NC}  $1"; }
warn()    { echo -e "${YELLOW}⚠${NC}  $1"; }
err()     { echo -e "${RED}✗${NC}  $1"; }
pause()   { echo ""; read -rp "${DIM}Nhấn Enter để tiếp tục...${NC}"; }
title()   { echo -e "\n${BOLD}${CYAN}══════ $1 ══════${NC}\n"; }
check_root() { [ "$EUID" -ne 0 ] && err "Cần sudo" && exit 1; }
check_docker() { command -v docker &>/dev/null || { err "Docker chưa cài. Chạy menu → 1. Install"; exit 1; }; }

# ===== STATUS BANNER =====

show_header() {
    clear
    echo -e "${CYAN}${BOLD}"
    cat << 'BANNER'
 ██╗   ██╗██████╗ ███████╗██╗███████╗██╗   ██╗
 ██║   ██║██╔══██╗██╔════╝██║██╔════╝██║   ██║
 ██║   ██║██████╔╝█████╗  ██║███████╗██║   ██║
 ╚██╗ ██╔╝██╔══██╗██╔══╝  ██║╚════██║██║   ██║
  ╚████╔╝ ██████╔╝███████╗██║███████║╚██████╔╝
   ╚═══╝  ╚═════╝ ╚══════╝╚═╝╚══════╝ ╚═════╝
BANNER
    echo -e "${NC}"

    # System info bar
    local hostname=$(hostname)
    local ip=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "?")
    local os=$(cat /etc/os-release 2>/dev/null | grep PRETTY_NAME | cut -d'"' -f2 || echo "Linux")
    local uptime_str=$(uptime -p 2>/dev/null | sed 's/up //' || echo "?")
    local cpu_cores=$(nproc 2>/dev/null || echo "?")
    local ram_info=$(free -h 2>/dev/null | awk '/Mem:/ {printf "%s / %s", $3, $2}' || echo "?")
    local disk_info=$(df -h / 2>/dev/null | awk 'NR==2 {printf "%s / %s (%s)", $3, $2, $5}' || echo "?")
    local docker_status=$(systemctl is-active docker 2>/dev/null || echo "not installed")
    local containers=$(docker ps -q 2>/dev/null | wc -l || echo "0")

    echo -e "${DIM}┌─────────────────────────────────────────────────────────┐${NC}"
    printf "${DIM}│${NC} ${BOLD}Host:${NC} %-16s ${BOLD}IP:${NC} %-15s ${BOLD}Uptime:${NC} %-14s${DIM}│${NC}\n" "$hostname" "$ip" "$uptime_str"
    printf "${DIM}│${NC} ${BOLD}OS:${NC} %-50s${DIM}│${NC}\n" "${os:0:50}"
    printf "${DIM}│${NC} ${BOLD}CPU:${NC} %-14s ${BOLD}RAM:${NC} %-14s ${BOLD}Disk:${NC} %-16s${DIM}│${NC}\n" "$cpu_cores cores" "$ram_info" "$disk_info"
    printf "${DIM}│${NC} ${BOLD}Docker:${NC} %-12s ${BOLD}Containers:${NC} %-8s ${BOLD}Apps dir:${NC} %-12s${DIM}│${NC}\n" "$docker_status" "$containers" "/opt"
    echo -e "${DIM}└─────────────────────────────────────────────────────────┘${NC}"
    echo ""
}

# ===== MENU SCREENS =====

menu_main() {
    while true; do
        show_header
        echo -e "${BOLD}MAIN MENU${NC} — Chọn số rồi Enter (hoặc q để thoát)"
        echo ""
        echo -e "  ${CYAN}1${NC})  📦 Install Server     ${DIM}(Docker + Traefik + Security)${NC}"
        echo -e "  ${CYAN}2${NC})  🚀 Deploy Apps        ${DIM}(Visota / Portainer / Metabase / n8n)${NC}"
        echo -e "  ${CYAN}3${NC})  📊 System Status      ${DIM}(CPU / RAM / Disk / Docker)${NC}"
        echo -e "  ${CYAN}4${NC})  📋 Container List     ${DIM}(Containers đang chạy)${NC}"
        echo -e "  ${CYAN}5${NC})  📜 Logs Viewer        ${DIM}(Web / Worker / DB / Traefik)${NC}"
        echo -e "  ${CYAN}6${NC})  🔄 Restart Service    ${DIM}(Restart 1 hoặc tất cả)${NC}"
        echo -e "  ${CYAN}7${NC})  💾 Backup             ${DIM}(Database + Media files)${NC}"
        echo -e "  ${CYAN}8${NC})  ♻️  Restore            ${DIM}(Restore từ file backup)${NC}"
        echo -e "  ${CYAN}9${NC})  ⬆️  Update Visota      ${DIM}(Git pull + rebuild + migrate)${NC}"
        echo -e "  ${CYAN}10${NC}) 🔧 Django Manage     ${DIM}(Shell / Superuser / Migrate)${NC}"
        echo -e "  ${CYAN}11${NC}) 🔒 Security Audit    ${DIM}(SSH / Firewall / fail2ban)${NC}"
        echo -e "  ${CYAN}12${NC}) 🗄️ Cleanup            ${DIM}(Docker prune + log rotate)${NC}"
        echo -e "  ${CYAN}13${NC}) 🎌 Shell Access      ${DIM}(Bash vào container)${NC}"
        echo -e "  ${CYAN}14${NC}) 🌐 SSL Certificates  ${DIM}(Check Let's Encrypt)${NC}"
        echo -e "  ${CYAN}15${NC}) ⚙️  Configuration     ${DIM}(Edit .env / Traefik config)${NC}"
        echo ""
        echo -e "  ${YELLOW}q${NC})  Thoát"
        echo ""
        read -rp "${BOLD}Chọn [1-15/q]:${NC} " choice

        case "$choice" in
            1)  menu_install ;;
            2)  menu_deploy ;;
            3)  cmd_status; pause ;;
            4)  cmd_apps; pause ;;
            5)  menu_logs ;;
            6)  menu_restart ;;
            7)  cmd_backup; pause ;;
            8)  menu_restore ;;
            9)  cmd_update; pause ;;
            10) menu_manage ;;
            11) cmd_security; pause ;;
            12) cmd_cleanup; pause ;;
            13) menu_shell ;;
            14) cmd_ssl; pause ;;
            15) menu_config ;;
            q|Q) echo -e "${GREEN}Tạm biệt! 👋${NC}"; exit 0 ;;
            *)  warn "Lựa chọn không hợp lệ"; sleep 1 ;;
        esac
    done
}

menu_install() {
    check_root
    show_header
    title "INSTALL SERVER"
    warn "Việc này sẽ cài đặt: Docker CE, Traefik, firewalld, fail2ban"
    echo ""
    read -p "Email Let's Encrypt (cho SSL): " le_email
    read -p "Xác nhận cài đặt? (yes/no): " confirm
    [ "$confirm" != "yes" ] && warn "Hủy" && return

    # OS update
    info "Updating system..."
    dnf update -y

    # Remove conflicts
    info "Removing conflicting packages..."
    dnf remove -y podman buildah runc 2>/dev/null || true

    # Docker
    info "Installing Docker CE..."
    dnf install -y dnf-utils
    dnf config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo
    dnf install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
    systemctl enable --now docker
    ok "Docker: $(docker --version)"

    # Firewall
    info "Configuring firewall..."
    systemctl enable --now firewalld
    firewall-cmd --permanent --add-service=ssh
    firewall-cmd --permanent --add-service=http
    firewall-cmd --permanent --add-service=https
    firewall-cmd --reload
    ok "Firewall: ssh + http + https"

    # Network
    info "Creating Docker network..."
    docker network create web 2>/dev/null || true
    ok "Network 'web' ready"

    # Traefik
    info "Installing Traefik..."
    mkdir -p /opt/traefik/letsencrypt
    _write_traefik_compose
    _write_traefik_config "$le_email"
    cd /opt/traefik && docker compose up -d
    ok "Traefik: dashboard http://$(hostname -I | awk '{print $1}'):8080"

    # Security
    info "Hardening..."
    _install_security
    local ru="${SUDO_USER:-$USER}"
    usermod -aG docker "$ru"
    ok "User '$ru' in docker group"

    echo ""
    ok "═══ INSTALL COMPLETE ═══"
    info "Bước tiếp: Menu → 2. Deploy Apps"
    pause
}

menu_deploy() {
    while true; do
        show_header
        echo -e "${BOLD}DEPLOY APPS${NC}"
        echo ""
        echo -e "  ${CYAN}1${NC}) 🧮 Visota ERP      ${DIM}(kế toán + CRM + HĐĐT)${NC}"
        echo -e "  ${CYAN}2${NC}) 🐳 Portainer       ${DIM}(Docker management UI)${NC}"
        echo -e "  ${CYAN}3${NC}) 📈 Metabase        ${DIM}(Analytics / BI)${NC}"
        echo -e "  ${CYAN}4${NC}) 🔗 n8n             ${DIM}(Workflow automation)${NC}"
        echo -e "  ${CYAN}5${NC}) 🌐 Traefik config  ${DIM}(Edit domains/SSL email)${NC}"
        echo ""
        echo -e "  ${YELLOW}0${NC}) ← Quay lại"
        echo ""
        read -rp "${BOLD}Chọn [1-5/0]:${NC} " choice

        case "$choice" in
            1)  read -p "Domain (mặc định: visota.net): " domain
                _deploy_visota "${domain:-visota.net}"; pause ;;
            2)  read -p "Domain (mặc định: docker.visota.net): " domain
                _deploy_portainer "${domain:-docker.visota.net}"; pause ;;
            3)  read -p "Domain (mặc định: analytics.visota.net): " domain
                _deploy_metabase "${domain:-analytics.visota.net}"; pause ;;
            4)  read -p "Domain (mặc định: flow.visota.net): " domain
                _deploy_n8n "${domain:-flow.visota.net}"; pause ;;
            5)  menu_traefik_config ;;
            0)  break ;;
            *)  warn "Không hợp lệ"; sleep 1 ;;
        esac
    done
}

menu_logs() {
    show_header
    echo -e "${BOLD}LOGS VIEWER${NC}"
    echo ""
    echo -e "  ${CYAN}1${NC}) 🌐 Web (Django/Gunicorn)"
    echo -e "  ${CYAN}2${NC}) ⚙️  Worker (django-q2)"
    echo -e "  ${CYAN}3${NC}) 🗄️  Database (MariaDB)"
    echo -e "  ${CYAN}4${NC}) 🔀 Traefik (proxy/SSL)"
    echo -e "  ${CYAN}5${NC}) 📊 Tất cả (compose logs)"
    echo ""
    echo -e "  ${YELLOW}0${NC}) ← Quay lại"
    echo ""
    read -rp "${BOLD}Chọn [1-5/0]:${NC} " choice

    case "$choice" in
        1) cd "$APP_DIR" 2>/dev/null && docker compose logs -f --tail=50 web || warn "Visota chưa deploy" ;;
        2) cd "$APP_DIR" 2>/dev/null && docker compose logs -f --tail=50 worker || warn "Visota chưa deploy" ;;
        3) cd "$APP_DIR" 2>/dev/null && docker compose logs -f --tail=50 db || warn "Visota chưa deploy" ;;
        4) cd "$TRAEFIK_DIR" 2>/dev/null && docker compose logs -f --tail=50 traefik || warn "Traefik chưa cài" ;;
        5) cd "$APP_DIR" 2>/dev/null && docker compose logs -f --tail=20 || warn "Visota chưa deploy" ;;
        0) return ;;
        *) warn "Không hợp lệ" ;;
    esac
    pause
}

menu_restart() {
    show_header
    echo -e "${BOLD}RESTART SERVICE${NC}"
    echo ""
    echo -e "  ${CYAN}1${NC}) 🌐 Web only"
    echo -e "  ${CYAN}2${NC}) ⚙️  Worker only"
    echo -e "  ${CYAN}3${NC}) 🗄️  Database only"
    echo -e "  ${CYAN}4${NC}) 🔀 Traefik only"
    echo -e "  ${CYAN}5${NC}) 💥 Tất cả Visota (web + worker + db)"
    echo ""
    echo -e "  ${YELLOW}0${NC}) ← Quay lại"
    echo ""
    read -rp "${BOLD}Chọn [1-5/0]:${NC} " choice

    case "$choice" in
        1) cd "$APP_DIR" 2>/dev/null && docker compose restart web && ok "Web restarted" ;;
        2) cd "$APP_DIR" 2>/dev/null && docker compose restart worker && ok "Worker restarted" ;;
        3) cd "$APP_DIR" 2>/dev/null && docker compose restart db && ok "DB restarted" ;;
        4) cd "$TRAEFIK_DIR" 2>/dev/null && docker compose restart traefik && ok "Traefik restarted" ;;
        5) cd "$APP_DIR" 2>/dev/null && docker compose restart && ok "All restarted" ;;
        0) return ;;
        *) warn "Không hợp lệ" ;;
    esac
    pause
}

menu_restore() {
    show_header
    echo -e "${BOLD}RESTORE FROM BACKUP${NC}"
    echo ""
    if [ ! -d "$BACKUP_DIR" ] || [ -z "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]; then
        warn "Chưa có backup nào"
        pause
        return
    fi
    echo "Backups có sẵn:"
    local i=1
    declare -a files
    for f in "$BACKUP_DIR"/*.sql.gz; do
        [ -f "$f" ] || continue
        files[$i]="$f"
        local fname=$(basename "$f")
        local fsize=$(du -h "$f" | awk '{print $1}')
        local fdate=$(echo "$fname" | grep -oP '\d{8}_\d{6}' | head -1)
        printf "  %s) %-40s %s\n" "$i" "$fname" "$fsize"
        ((i++))
    done
    echo ""
    echo -e "  ${YELLOW}0${NC}) ← Quay lại"
    echo ""
    read -rp "${BOLD}Chọn file [1-$((i-1))/0]:${NC} " choice
    [ "$choice" = "0" ] && return
    [ -z "${files[$choice]:-}" ] && warn "Không hợp lệ" && pause && return

    warn "Sẽ OVERWRITE database hiện tại!"
    read -p "Gõ 'RESTORE' để xác nhận: " confirm
    [ "$confirm" != "RESTORE" ] && warn "Hủy" && pause && return

    source "$APP_DIR/.env" 2>/dev/null
    cd "$APP_DIR"
    info "Restoring from ${files[$choice]}..."
    gunzip < "${files[$choice]}" | docker compose exec -T db mysql -u root -p"${DB_ROOT_PASSWORD}" "${DB_NAME:-visota}" 2>/dev/null
    docker compose restart web worker
    ok "Restore hoàn tất"
    pause
}

menu_manage() {
    while true; do
        show_header
        echo -e "${BOLD}DJANGO MANAGEMENT${NC}"
        echo ""
        echo -e "  ${CYAN}1${NC}) 🐍 Shell            ${DIM}(python manage.py shell)${NC}"
        echo -e "  ${CYAN}2${NC}) 👤 Tạo Superuser    ${DIM}(tạo admin mới)${NC}"
        echo -e "  ${CYAN}3${NC}) 🔄 Migrate           ${DIM}(chạy database migrations)${NC}"
        echo -e "  ${CYAN}4${NC}) 📁 Collect Static   ${DIM}(re-collect CSS/JS)${NC}"
        echo -e "  ${CYAN}5${NC}) 🌱 Seed Permissions ${DIM}(reset 25 module permissions)${NC}"
        echo -e "  ${CYAN}6${NC}) 📊 Seed Demo Data   ${DIM}(tạo data mẫu để test)${NC}"
        echo -e "  ${CYAN}7${NC}) 💣 Flush (DANGER)   ${DIM}(xóa toàn bộ data!)${NC}"
        echo ""
        echo -e "  ${YELLOW}0${NC}) ← Quay lại"
        echo ""
        read -rp "${BOLD}Chọn [1-7/0]:${NC} " choice

        case "$choice" in
            1) cd "$APP_DIR" && docker compose exec web python manage.py shell ;;
            2) cd "$APP_DIR" && docker compose exec -it web python manage.py createsuperuser ;;
            3) cd "$APP_DIR" && docker compose exec web python manage.py migrate && ok "Migrate done" ;;
            4) cd "$APP_DIR" && docker compose exec web python manage.py collectstatic --noinput && ok "Static collected" ;;
            5) cd "$APP_DIR" && docker compose exec web python manage.py seed_permissions --reset && ok "Permissions seeded" ;;
            6) cd "$APP_DIR" && docker compose exec web python manage.py seed_demo && ok "Demo data loaded" ;;
            7) warn "XÓA TOÀN BỘ DATA!"; read -p "Gõ 'DELETE' để xác nhận: " c
                [ "$c" = "DELETE" ] && cd "$APP_DIR" && docker compose exec web python manage.py flush --noinput && ok "Data flushed" ;;
            0) break ;;
            *) warn "Không hợp lệ"; sleep 1 ;;
        esac
        [ "$choice" != "1" ] && pause
    done
}

menu_shell() {
    show_header
    echo -e "${BOLD}CONTAINER SHELL${NC}"
    echo ""
    echo -e "  ${CYAN}1${NC}) 🌐 Web container"
    echo -e "  ${CYAN}2${NC}) ⚙️  Worker container"
    echo -e "  ${CYAN}3${NC}) 🗄️  DB container"
    echo ""
    echo -e "  ${YELLOW}0${NC}) ← Quay lại"
    echo ""
    read -rp "${BOLD}Chọn [1-3/0]:${NC} " choice
    case "$choice" in
        1) cd "$APP_DIR" && docker compose exec web bash ;;
        2) cd "$APP_DIR" && docker compose exec worker bash ;;
        3) docker exec -it visota-db mariadb -u root -p$(grep DB_ROOT_PASSWORD "$APP_DIR/.env" | cut -d= -f2) ;;
        0) return ;;
    esac
}

menu_config() {
    while true; do
        show_header
        echo -e "${BOLD}CONFIGURATION${NC}"
        echo ""
        echo -e "  ${CYAN}1${NC}) ✏️  Edit .env             ${DIM}(mật khẩu, email, domain)${NC}"
        echo -e "  ${CYAN}2${NC}) ✏️  Edit Traefik config    ${DIM}(SSL email, routing)${NC}"
        echo -e "  ${CYAN}3${NC}) ✏️  Edit MariaDB config    ${DIM}(tuning, charset)${NC}"
        echo -e "  ${CYAN}4${NC}) 🔄 Restart Traefik       ${DIM}(sau khi sửa config)${NC}"
        echo -e "  ${CYAN}5${NC}) 📋 Show .env (masked)    ${DIM}(xem config, ẩn password)${NC}"
        echo ""
        echo -e "  ${YELLOW}0${NC}) ← Quay lại"
        echo ""
        read -rp "${BOLD}Chọn [1-5/0]:${NC} " choice
        case "$choice" in
            1) ${EDITOR:-nano} "$APP_DIR/.env" ;;
            2) ${EDITOR:-nano} "$TRAEFIK_DIR/traefik.yml" ;;
            3) ${EDITOR:-nano} "$APP_DIR/docker/mariadb.cnf" 2>/dev/null || warn "File not found" ;;
            4) cd "$TRAEFIK_DIR" && docker compose restart traefik && ok "Traefik restarted" ;;
            5) show_env_masked ;;
            0) break ;;
            *) warn "Không hợp lệ"; sleep 1 ;;
        esac
        pause
    done
}

show_env_masked() {
    title ".env (masked)"
    if [ -f "$APP_DIR/.env" ]; then
        sed -E 's/(PASSWORD=).+/\1*****/' "$APP_DIR/.env" | sed -E 's/(SECRET_KEY=).+/\1*****/'
    else
        warn ".env not found"
    fi
}

menu_traefik_config() {
    show_header
    echo -e "${BOLD}TRAEFIK CONFIG${NC}"
    echo ""
    read -p "Email Let's Encrypt mới: " new_email
    [ -z "$new_email" ] && warn "Hủy" && return
    sed -i "s/email: .*/email: \"$new_email\"/" "$TRAEFIK_DIR/traefik.yml"
    cd "$TRAEFIK_DIR" && docker compose restart traefik
    ok "Traefik email updated: $new_email"
    pause
}

# ===== COMMANDS (non-interactive) =====

cmd_status() {
    title "SYSTEM STATUS"
    info "Host: $(hostname) | IP: $(hostname -I 2>/dev/null | awk '{print $1}')"
    info "OS: $(cat /etc/os-release | grep PRETTY_NAME | cut -d'"' -f2)"
    info "Uptime: $(uptime -p)"
    echo ""
    local cpu_cores=$(nproc)
    local ram_total=$(free -h | awk '/Mem:/ {print $2}')
    local ram_used=$(free -h | awk '/Mem:/ {print $3}')
    info "CPU: ${cpu_cores} cores"
    info "RAM: ${ram_used}/${ram_total}"
    info "Disk: $(df -h / | awk 'NR==2 {print $3"/"$2" ("$5")"}')"
    if command -v docker &>/dev/null; then
        echo ""
        docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || true
        echo ""
        docker stats --no-stream --format "table {{.Name}}\t{{.CPUPerc}}\t{{.MemUsage}}" 2>/dev/null || true
    fi
}

cmd_apps() {
    title "CONTAINERS"
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Image}}" 2>/dev/null || warn "Docker not running"
}

cmd_backup() {
    check_root
    title "BACKUP"
    mkdir -p "$BACKUP_DIR"
    local ts=$(date +%Y%m%d_%H%M%S)
    if [ -f "$APP_DIR/.env" ]; then
        source "$APP_DIR/.env"
        cd "$APP_DIR"
        info "Backing up database..."
        docker compose exec -T db mysqldump -u root -p"${DB_ROOT_PASSWORD}" "${DB_NAME:-visota}" 2>/dev/null | gzip > "$BACKUP_DIR/visota_db_${ts}.sql.gz"
        ok "DB: visota_db_${ts}.sql.gz ($(du -h "$BACKUP_DIR/visota_db_${ts}.sql.gz" | awk '{print $1}'))"
        # Media
        docker run --rm -v visota_media_files:/data:ro -v "$BACKUP_DIR:/backup" alpine tar czf "/backup/visota_media_${ts}.tar.gz" /data 2>/dev/null
        ok "Media: visota_media_${ts}.tar.gz"
        # Cleanup
        find "$BACKUP_DIR" -name "*.gz" -mtime +30 -delete
        info "Old backups (>30 days) cleaned"
    else
        warn "Visota chưa deploy — không có gì để backup"
    fi
}

cmd_update() {
    check_root
    title "UPDATE VISOTA"
    cd "$APP_DIR"
    info "Pulling code..."
    git pull origin main
    info "Rebuilding..."
    docker compose up -d --build
    info "Migrating..."
    docker compose exec -T web python manage.py migrate --noinput
    info "Collecting static..."
    docker compose exec -T web python manage.py collectstatic --noinput
    info "Seeding permissions..."
    docker compose exec -T web python manage.py seed_permissions 2>/dev/null || true
    ok "Update complete"
}

cmd_security() {
    check_root
    title "SECURITY AUDIT"
    local issues=0

    info "SSH password auth: $(grep -i PasswordAuthentication /etc/ssh/sshd_config | tail -1 | awk '{print $2}')"
    [ "$(grep -i PasswordAuthentication /etc/ssh/sshd_config | tail -1 | awk '{print $2}')" = "yes" ] && { warn "⚠ SSH password auth đang BẬT"; ((issues++)); }

    systemctl is-active --quiet fail2ban 2>/dev/null && ok "fail2ban: active" || { warn "⚠ fail2ban: not running"; ((issues++)); }
    systemctl is-active --quiet firewalld 2>/dev/null && ok "firewalld: active" || { warn "⚠ firewalld: not running"; ((issues++)); }
    systemctl is-active --quiet dnf-automatic.timer 2>/dev/null && ok "Auto-updates: enabled" || { warn "⚠ Auto-updates: disabled"; ((issues++)); }

    local disk_pct=$(df / | awk 'NR==2 {gsub(/%/,""); print $5}')
    [ "$disk_pct" -gt 80 ] && { err "🚨 Disk ${disk_pct}% CRITICAL"; ((issues++)); }
    [ "$disk_pct" -gt 60 ] && [ "$disk_pct" -le 80 ] && warn "Disk ${disk_pct}%"

    echo ""
    [ "$issues" -eq 0 ] && ok "✓ Không phát hiện vấn đề" || warn "$issues vấn đề cần xử lý"
}

cmd_cleanup() {
    check_root
    title "DOCKER CLEANUP"
    info "Images..."
    docker image prune -f 2>/dev/null
    info "Volumes..."
    docker volume prune -f 2>/dev/null
    info "Containers..."
    docker container prune -f 2>/dev/null
    info "Build cache..."
    docker builder prune -f 2>/dev/null
    info "Old logs..."
    journalctl --vacuum-time=7d 2>/dev/null || true
    ok "Cleanup done"
}

cmd_ssl() {
    title "SSL CERTIFICATES"
    if [ -f "$TRAEFIK_DIR/letsencrypt/acme.json" ]; then
        info "Traefik ACME certs:"
        cat "$TRAEFIK_DIR/letsencrypt/acme.json" 2>/dev/null | python3 -c "
import json,sys
try:
    d=json.load(sys.stdin)
    for r,certs in d.items():
        for dom,cert in certs.get('Certificates',{}).items():
            print(f'  ✓ {dom}')
except: print('  (cannot parse)')
" 2>/dev/null || info "  (parsing acme.json)"
    else
        warn "No acme.json — SSL auto-generates when domains resolve"
    fi
}

cmd_logs() {
    local svc="${1:-web}"
    case "$svc" in
        traefik) cd "$TRAEFIK_DIR" 2>/dev/null && docker compose logs -f --tail=50 traefik ;;
        *) cd "$APP_DIR" 2>/dev/null && docker compose logs -f --tail=50 "$svc" ;;
    esac
}

# ===== INTERNAL =====

_write_traefik_compose() {
    cat > /opt/traefik/docker-compose.yml << 'EOF'
services:
  traefik:
    image: traefik:v3.2
    container_name: traefik
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "8080:8080"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - ./letsencrypt:/letsencrypt
      - ./traefik.yml:/etc/traefik/traefik.yml:ro
    networks:
      - web
networks:
  web:
    external: true
EOF
}

_write_traefik_config() {
    local email="${1:-admin@visota.net}"
    cat > /opt/traefik/traefik.yml << EOF
api:
  dashboard: true
  insecure: true
entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
  websecure:
    address: ":443"
providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false
certificatesResolvers:
  letsencrypt:
    acme:
      email: "$email"
      storage: /letsencrypt/acme.json
      httpChallenge:
        entryPoint: web
EOF
}

_install_security() {
    dnf install -y epel-release fail2ban 2>/dev/null || true
    cat > /etc/fail2ban/jail.local << 'EOF'
[DEFAULT]
bantime = 3600
findtime = 600
maxretry = 5
banaction = firewallcmd-ipset
[sshd]
enabled = true
EOF
    systemctl enable --now fail2ban 2>/dev/null || true
    dnf install -y dnf-automatic 2>/dev/null || true
    systemctl enable --now dnf-automatic.timer 2>/dev/null || true
    ok "fail2ban + auto-updates enabled"
}

_deploy_visota() {
    local domain="$1"
    title "DEPLOY VISOTA ($domain)"
    mkdir -p "$APP_DIR"; cd "$APP_DIR"
    if [ -d ".git" ]; then
        info "Updating..."
        git pull origin main
    else
        info "Cloning..."
        git clone https://github.com/pkm2025/visota.git .
    fi
    if [ ! -f ".env" ]; then
        info "Generating .env..."
        local secret=$(openssl rand -hex 32)
        local db_pass=$(openssl rand -hex 16)
        local admin_pass=$(openssl rand -base64 12)
        cat > .env << EENV
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=${secret}
DB_ROOT_PASSWORD=${db_pass}
DB_NAME=visota
DB_USER=visota
DB_PASSWORD=${db_pass}
SUPERUSER_EMAIL=admin@${domain}
SUPERUSER_PASSWORD=${admin_pass}
ALLOWED_HOSTS=${domain},www.${domain},localhost
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@${domain}
EMAIL_HOST_PASSWORD=
GUNICORN_WORKERS=4
EENV
        echo ""
        echo -e "${GREEN}${BOLD}═══ THÔNG TIN ĐĂNG NHẬP ═══${NC}"
        echo -e "  URL:      ${CYAN}https://${domain}/${NC}"
        echo -e "  Admin:    ${CYAN}admin${NC}"
        echo -e "  Password: ${YELLOW}${admin_pass}${NC}"
        echo -e "${RED}Lưu lại mật khẩu này!${NC}"
        echo ""
    fi
    _write_visota_compose "$domain"
    info "Building (3-5 min first time)..."
    docker compose up -d --build
    ok "Visota deployed: https://${domain}/"
}

_write_visota_compose() {
    local domain="$1"
    cat > "$APP_DIR/docker-compose.yml" << VEOF
services:
  web:
    build: .
    container_name: visota-web
    restart: unless-stopped
    env_file: .env
    environment:
      - DJANGO_SETTINGS_MODULE=config.settings.prod
      - DB_HOST=db
      - DB_PORT=3306
    volumes:
      - static_files:/app/staticfiles
      - media_files:/app/media
    depends_on:
      db:
        condition: service_healthy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.visota.rule=Host(\`${domain}\`,\`www.${domain}\`)"
      - "traefik.http.routers.visota.entrypoints=websecure"
      - "traefik.http.routers.visota.tls.certresolver=letsencrypt"
      - "traefik.http.services.visota.loadbalancer.server.port=8900"
    networks: [web, visota-net]
  worker:
    build: .
    container_name: visota-worker
    restart: unless-stopped
    command: python manage.py qcluster
    env_file: .env
    environment:
      - DJANGO_SETTINGS_MODULE=config.settings.prod
      - DB_HOST=db
      - DB_PORT=3306
    volumes:
      - media_files:/app/media
    depends_on:
      db:
        condition: service_healthy
    networks: [visota-net]
  db:
    image: mariadb:11.4
    container_name: visota-db
    restart: unless-stopped
    environment:
      - MYSQL_ROOT_PASSWORD=\${DB_ROOT_PASSWORD}
      - MYSQL_DATABASE=\${DB_NAME:-visota}
      - MYSQL_USER=\${DB_USER:-visota}
      - MYSQL_PASSWORD=\${DB_PASSWORD}
    volumes:
      - db_data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mariadb-admin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks: [visota-net]
volumes:
  db_data:
  static_files:
  media_files:
networks:
  web:
    external: true
  visota-net:
    driver: bridge
VEOF
}

