[Unit]
Description=Visota Uvicorn
After=network.target mariadb.service

[Service]
Type=notify
User=visota
Group=www-data
WorkingDirectory=/opt/visota/app
EnvironmentFile=/opt/visota/.env
ExecStart=/opt/visota/app/.venv/bin/uvicorn config.asgi:application --host 127.0.0.1 --port 8900 --workers 12 --log-level info --access-log
ExecReload=/bin/kill -s HUP $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
